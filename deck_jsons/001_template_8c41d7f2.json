      "html": "\n<style>\n.diagram-section {\n  background: var(--teal-900, #042d2d);\n  padding: 64px 72px 72px;\n  position: relative;\n  overflow: hidden;\n  border-radius: 12px;\n  margin-top: 16px;\n  border: 1px solid rgba(139,92,246,0.3);\n}\n.diagram-section::before {\n  content: '';\n  position: absolute; inset: 0;\n  background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(139,92,246,0.1) 0%, transparent 70%);\n}\n.diagram-title {\n  text-align: center;\n  font-family: 'DM Mono', monospace;\n  font-size: 10px;\n  letter-spacing: 0.25em;\n  text-transform: uppercase;\n  color: var(--medium, #8b5cf6);\n  margin-bottom: 48px;\n  position: relative;\n}\n.hub-container {\n  position: relative;\n  max-width: 900px;\n  margin: 0 auto;\n}\n#hub-svg {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n</style>\n\n<div class=\"diagram-section\">\n  <div class=\"diagram-title\">Bespoke Vector Animation Wrapper</div>\n  <div class=\"hub-container\">\n    <svg id=\"hub-svg\" viewBox=\"0 0 900 560\" xmlns=\"http://www.w3.org/2000/svg\">\n      <defs>\n        <radialGradient id=\"hubGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n          <stop offset=\"0%\" stop-color=\"#8b5cf6\" stop-opacity=\"0.15\"/>\n          <stop offset=\"100%\" stop-color=\"#160f2b\" stop-opacity=\"0\"/>\n        </radialGradient>\n        <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n          <path d=\"M0,0 L0,6 L6,3 z\" fill=\"rgba(139,92,246,0.5)\"/>\n        </marker>\n        <filter id=\"glow\">\n          <feGaussianBlur stdDeviation=\"3\" result=\"blur\"/>\n          <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n        </filter>\n      </defs>\n\n      <ellipse cx=\"450\" cy=\"280\" rx=\"340\" ry=\"220\" fill=\"url(#hubGrad)\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"345\" y2=\"98\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"555\" y2=\"98\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"660\" y2=\"280\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"555\" y2=\"462\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"345\" y2=\"462\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n      <line x1=\"450\" y1=\"280\" x2=\"240\" y2=\"280\" stroke=\"rgba(139,92,246,0.25)\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\"/>\n\n      <circle cx=\"450\" cy=\"280\" r=\"78\" fill=\"none\" stroke=\"rgba(139,92,246,0.2)\" stroke-width=\"1\">\n        <animate attributeName=\"r\" values=\"78;92;78\" dur=\"3s\" repeatCount=\"indefinite\"/>\n        <animate attributeName=\"stroke-opacity\" values=\"0.2;0.05;0.2\" dur=\"3s\" repeatCount=\"indefinite\"/>\n      </circle>\n      <circle cx=\"450\" cy=\"280\" r=\"65\" fill=\"none\" stroke=\"rgba(139,92,246,0.3)\" stroke-width=\"1\"/>\n\n      <circle cx=\"450\" cy=\"280\" r=\"60\" fill=\"#1e143f\" stroke=\"rgba(139,92,246,0.6)\" stroke-width=\"1.5\" filter=\"url(#glow)\"/>\n      <text x=\"450\" y=\"272\" text-anchor=\"middle\" font-family=\"'DM Serif Display', serif\" font-size=\"17\" font-weight=\"400\" fill=\"rgba(255,255,255,0.9)\" letter-spacing=\"0.5\">Core</text>\n      <text x=\"450\" y=\"292\" text-anchor=\"middle\" font-family=\"'DM Serif Display', serif\" font-size=\"17\" font-style=\"italic\" fill=\"#8b5cf6\" letter-spacing=\"0.5\">Engine</text>\n\n      <!-- Nodes -->\n      <g class=\"pillar-node\">\n        <circle cx=\"345\" cy=\"98\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"0s\"/>\n        </circle>\n        <text x=\"345\" y=\"84\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T1</text>\n        <text x=\"345\" y=\"106\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">Hero</text>\n      </g>\n      <g class=\"pillar-node\">\n        <circle cx=\"555\" cy=\"98\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"0.6s\"/>\n        </circle>\n        <text x=\"555\" y=\"84\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T2</text>\n        <text x=\"555\" y=\"106\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">Process</text>\n      </g>\n      <g class=\"pillar-node\">\n        <circle cx=\"660\" cy=\"280\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"1.2s\"/>\n        </circle>\n        <text x=\"660\" y=\"266\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T3</text>\n        <text x=\"660\" y=\"288\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">GridCards</text>\n      </g>\n      <g class=\"pillar-node\">\n        <circle cx=\"555\" cy=\"462\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"1.8s\"/>\n        </circle>\n        <text x=\"555\" y=\"448\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T4</text>\n        <text x=\"555\" y=\"470\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">BeforeAfter</text>\n      </g>\n      <g class=\"pillar-node\">\n        <circle cx=\"345\" cy=\"462\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"2.4s\"/>\n        </circle>\n        <text x=\"345\" y=\"448\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T5</text>\n        <text x=\"345\" y=\"470\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">Timeline</text>\n      </g>\n      <g class=\"pillar-node\">\n        <circle cx=\"240\" cy=\"280\" r=\"58\" fill=\"#2a1b54\" stroke=\"rgba(139,92,246,0.5)\" stroke-width=\"1.5\">\n          <animate attributeName=\"stroke-opacity\" values=\"0.5;1;0.5\" dur=\"4s\" repeatCount=\"indefinite\" begin=\"3s\"/>\n        </circle>\n        <text x=\"240\" y=\"266\" text-anchor=\"middle\" font-family=\"DM Mono, monospace\" font-size=\"15\" fill=\"#8b5cf6\" letter-spacing=\"1\">T6</text>\n        <text x=\"240\" y=\"288\" text-anchor=\"middle\" font-family=\"'DM Sans', sans-serif\" font-size=\"18\" fill=\"white\">Tables</text>\n      </g>\n    </svg>\n  </div>\n</div>"
